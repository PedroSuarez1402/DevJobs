{
  "name": "devjobs",
  "version": "1.0.0",
  "description": "Portal de trabajo",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "server": "nodemon --env-file=.env index.js",
    "css:watch": "npx tailwindcss -i ./public/css/main.css -o ./public/css/app.css --watch",
    "dev": "concurrently \"npm run server\" \"npm run css:watch\"",
    "start": "node --env-file=.env index.js"
  },
  "author": "Pedro",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-flash": "^0.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.2",
    "express-session": "^1.19.0",
    "flatpickr": "^4.6.13",
    "jquery": "^4.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "nodemailer": "^8.0.2",
    "select2": "^4.1.0-rc.0",
    "sequelize": "^6.37.8",
    "shortid": "^2.2.17",
    "tagify": "^0.1.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "sequelize-cli": "^6.6.5",
    "tailwindcss": "^4.2.1"
  }
}
