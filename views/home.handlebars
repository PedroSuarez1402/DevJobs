<section class="mt-4">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-400">Vacantes Recientes</h2>
        <a href="/vacantes" class="text-xs font-medium text-emerald-400 hover:text-emerald-300 transition-colors">Ver todas &rarr;</a>
    </div>
    
    {{#if vacantes.length}}
        <div class="grid gap-3">
            {{#each vacantes}}
                <div class="bg-gray-900 border border-gray-800 p-4 rounded-lg flex items-center justify-between hover:border-emerald-500/50 hover:bg-gray-800/50 transition-all group shadow-sm">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                            <h3 class="text-base font-bold text-white truncate group-hover:text-emerald-400 transition-colors">{{titulo}}</h3>
                            <span class="px-1.5 py-0.5 bg-gray-800 text-[10px] font-black uppercase text-gray-500 rounded border border-gray-700">{{tipo_contrato}}</span>
                        </div>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <div class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                                <span>{{empresa}}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <span>{{ubicacion}}</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-bold text-white">${{salario}}</p>
                            <p class="text-[10px] text-gray-500 font-medium">Por mes</p>
                        </div>
                        <a href="/vacantes/{{url}}" class="bg-gray-800 hover:bg-emerald-500 hover:text-gray-950 text-emerald-400 font-bold uppercase py-2 px-4 rounded-md text-[10px] transition-all border border-gray-700 hover:border-emerald-500 active:scale-95">
                            Detalles
                        </a>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="bg-gray-900 border border-gray-800 border-dashed p-10 rounded-xl text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto text-gray-700 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <p class="text-sm text-gray-500 font-medium">No hay vacantes disponibles en este momento.</p>
            <a href="/vacantes/nueva" class="mt-4 inline-block text-xs font-bold text-emerald-400 hover:underline">Publica la primera vacante &rarr;</a>
        </div>
    {{/if}}
</section>
