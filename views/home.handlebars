<section class="mt-4">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-400">Vacantes Recientes</h2>
        <a href="/vacantes" class="text-xs font-medium text-emerald-400 hover:text-emerald-300 transition-colors">Ver todas &rarr;</a>
    </div>
    
    {{#if vacantes.length}}
        <div class="grid gap-3">
            {{#each vacantes}}
                <div class="bg-gray-900 border border-gray-800 p-4 rounded-lg flex items-center justify-between hover:border-emerald-500/50 hover:bg-gray-800/50 transition-all group shadow-sm">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                            <h3 class="text-base font-bold text-white truncate group-hover:text-emerald-400 transition-colors">{{titulo}}</h3>
                            <span class="px-1.5 py-0.5 bg-gray-800 text-[10px] font-black uppercase text-gray-500 rounded border border-gray-700">{{tipo_contrato}}</span>
                        </div>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-building text-[10px]"></i>
                                <span>{{creador.nombre}}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-location-dot text-[10px]"></i>
                                <span>{{ubicacion}}</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-bold text-white">${{salario}}</p>
                            <p class="text-[10px] text-gray-500 font-medium">Por mes</p>
                        </div>
                        <a href="/vacantes/{{id}}" class="bg-gray-800 hover:bg-emerald-500 hover:text-gray-950 text-emerald-400 font-bold uppercase py-2 px-4 rounded-md text-[10px] transition-all border border-gray-700 hover:border-emerald-500 active:scale-95">
                            Detalles
                        </a>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="bg-gray-900 border border-gray-800 border-dashed p-10 rounded-xl text-center">
            <i class="fa-solid fa-folder-open text-3xl text-gray-700 mb-3 block"></i>
            <p class="text-sm text-gray-500 font-medium">No hay vacantes disponibles en este momento.</p>
            <a href="/vacantes/nueva" class="mt-4 inline-block text-xs font-bold text-emerald-400 hover:underline">Publica la primera vacante &rarr;</a>
        </div>
    {{/if}}
</section>
