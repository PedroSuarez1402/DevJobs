<nav class="h-14 bg-gray-900 border-b border-gray-800 flex items-center px-4 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto w-full flex justify-between items-center gap-4">
        <!-- Logo y Botón Sidebar -->
        <div class="flex items-center gap-4">
            {{#if usuario}}
            <button id="toggleSidebar" class="p-1.5 hover:bg-gray-800 rounded-md text-gray-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            {{/if}}
            <a href="/" class="text-lg font-black text-emerald-500 tracking-tight">DevJobs</a>
        </div>

        <!-- Buscador Compacto -->
        {{#if barra}}
        <div class="flex-1 max-w-md hidden md:block">
            <form action="#" class="relative">
                <input type="text" placeholder="Buscar empleos..." 
                    class="w-full h-8 bg-gray-800 border-none rounded-md px-8 text-xs text-gray-200 placeholder-gray-500 focus:ring-1 focus:ring-emerald-500/50 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </form>
        </div>
        {{/if}}

        <!-- Acciones -->
        <div class="flex items-center gap-3">
            {{#if usuario}}
            <div class="flex items-center gap-2">
                <span class="text-xs text-gray-400 font-medium hidden sm:inline-block">Hola, {{usuario.nombre}}</span>
                <a href="/auth/logout" class="text-xs font-bold text-gray-400 hover:text-white transition-colors">Cerrar Sesión</a>
            </div>
            {{else}}
                {{#unless ocultarBotonesAuth}}
                <a href="/auth/login" class="text-xs font-bold text-gray-400 hover:text-white transition-colors">Iniciar Sesión</a>
                <a href="/auth/register" class="bg-emerald-500 hover:bg-emerald-400 text-gray-950 font-bold text-xs px-3 py-1.5 rounded-md transition-all shadow-lg shadow-emerald-500/10">Registrarse</a>
                {{/unless}}
            {{/if}}
        </div>
    </div>
</nav>
