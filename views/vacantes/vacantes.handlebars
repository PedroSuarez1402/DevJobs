<div class="max-w-7xl mx-auto mt-10 px-4">
    
    {{!-- Cabecera de la sección --}}
    <div class="flex flex-col md:flex-row justify-between items-center mb-10 border-b border-gray-800 pb-6">
        <div>
            <h1 class="text-4xl font-black text-white mb-2">Explorar Vacantes</h1>
            <p class="text-xl text-gray-400">Encuentra tu próximo desafío profesional</p>
        </div>
        <div class="mt-4 md:mt-0">
            <a href="/vacantes/nueva" class="bg-[#00C897] hover:bg-[#0a9b77] text-white font-bold py-3 px-6 rounded-lg text-lg transition-colors flex items-center gap-2">
                <i class="fa-solid fa-plus"></i> Publicar Vacante
            </a>
        </div>
    </div>

    {{!-- Contenedor de las Tarjetas --}}
    {{#if vacantes.length}}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {{#each vacantes}}
                {{!-- Tarjeta Estilo LinkedIn/Computrabajo --}}
                <div class="bg-white/5 border border-gray-800 p-6 rounded-2xl hover:border-[#00C897] hover:shadow-[0_0_15px_rgba(0,200,151,0.1)] transition-all flex flex-col justify-between group">
                    
                    <div>
                        {{!-- Título y Empresa --}}
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-2xl font-bold text-white group-hover:text-[#00C897] transition-colors mb-1">{{titulo}}</h3>
                                <div class="flex items-center gap-2 text-gray-400">
                                    <i class="fa-solid fa-user text-sm"></i>
                                    <span class="font-medium">{{creador.nombre}}</span>
                                </div>
                            </div>
                        </div>

                        {{!-- Detalles de la Vacante (Ubicación, Salario, Fecha) --}}
                        <div class="flex flex-wrap gap-4 text-sm text-gray-400 mb-6">
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-location-dot"></i>
                                <span>{{ubicacion}}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-money-bill-wave"></i>
                                <span class="text-white font-bold">${{salario}}</span>
                            </div>
                        </div>

                        {{!-- Descripción corta (Truncada) --}}
                        <p class="text-gray-500 line-clamp-3 mb-6">
                            {{descripcion}}
                        </p>
                    </div>

                    {{!-- Footer de la Tarjeta --}}
                    <div class="flex items-center justify-between border-t border-gray-800 pt-4 mt-auto">
                        {{!-- Etiqueta de Contrato --}}
                        <span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                            {{tipo_contrato}}
                        </span>
                        
                        {{!-- Botón de Acción --}}
                        <a href="/vacantes/{{id}}" class="text-[#00C897] font-bold hover:text-white transition-colors flex items-center gap-1 border border-[#00C897] hover:bg-[#00C897] px-4 py-2 rounded-lg">
                            Ver Detalles <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        {{!-- Estado Vacío (Empty State) --}}
        <div class="text-center py-20 bg-white/5 border border-gray-800 border-dashed rounded-2xl">
            <i class="fa-solid fa-briefcase text-6xl text-gray-600 mb-4 block"></i>
            <h2 class="text-2xl font-bold text-white mb-2">Aún no hay vacantes publicadas</h2>
            <p class="text-gray-400 mb-6">Sé el primero en publicar una oferta de trabajo en la plataforma.</p>
        </div>
    {{/if}}
</div>