<div class="max-w-4xl mx-auto mt-10 px-4">
    <div class="bg-white/5 p-10 rounded-2xl shadow-xl border border-gray-800">
        
        <div class="mb-8 border-b border-gray-800 pb-6">
            <h1 class="text-2xl font-black text-white mb-2">Publicar Nueva Vacante</h1>
            <p class="text-md text-gray-400">Completa la información para encontrar a tu candidato ideal.</p>
        </div>

        {{#if mensajes.error}}
            <div class="bg-red-500/20 border border-red-500 text-red-100 p-4 rounded-lg mb-6 text-center text-xl">
                {{mensajes.error}}
            </div>
        {{/if}}

        <form action="/vacantes/nueva" method="POST" class="space-y-6">
            
            {{!-- Título de la Vacante --}}
            <div>
                <label for="titulo" class="block text-md text-gray-400 mb-2">Título del Puesto</label>
                <input type="text" name="titulo" id="titulo" placeholder="Ej: Desarrollador React Senior" required
                    class="w-full bg-[#100E17] border border-gray-700 rounded-xl px-6 py-4 text-white text-sm focus:outline-none focus:border-[#00C897]">
            </div>

            {{!-- Contenedor de 2 columnas para Salario y Contrato --}}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="salario" class="block text-md text-gray-400 mb-2">Salario (Mensual)</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold">$</span>
                        <input type="number" name="salario" id="salario" placeholder="5000" step="0.01" required
                            class="w-full bg-[#100E17] border border-gray-700 rounded-xl pl-10 pr-6 py-4 text-white text-sm focus:outline-none focus:border-[#00C897]">
                    </div>
                </div>

                <div>
                    <label for="tipo_contrato" class="block text-md text-gray-400 mb-2">Tipo de Contrato</label>
                    <select name="tipo_contrato" id="tipo_contrato" required class="select2">
                        <option value="" disabled selected>-- Selecciona una opción --</option>
                        <option value="Indefinido">Término Indefinido</option>
                        <option value="Fijo">Término Fijo</option>
                        <option value="Proyecto">Por Proyecto / Freelance</option>
                    </select>
                </div>
            </div>

            {{!-- Ubicación --}}
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <label for="ubicacion" class="block text-md text-gray-400">Ubicación</label>
                    <label class="inline-flex items-center cursor-pointer group">
                        <input type="checkbox" name="remoto" id="remoto" class="sr-only peer">
                        <div class="relative w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:inset-s-0.5 after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                        <span class="ms-3 text-sm font-medium text-gray-400 group-hover:text-emerald-400 transition-colors">Trabajo Remoto</span>
                    </label>
                </div>
                <div id="ubicacion-container">
                    <select name="ubicacion" id="ubicacion" required class="select2-location">
                        <option value="" selected disabled>Buscar ciudad o país...</option>
                    </select>
                </div>
            </div>

            {{!-- Descripción --}}
            <div>
                <label for="descripcion" class="block text-md text-gray-400 mb-2">Descripción del Puesto</label>
                <textarea name="descripcion" id="descripcion" rows="6" placeholder="Requisitos, responsabilidades, beneficios..." required
                    class="w-full bg-[#100E17] border border-gray-700 rounded-xl px-6 py-4 text-white text-sm focus:outline-none focus:border-[#00C897]"></textarea>
            </div>

            {{!-- Botón Submit --}}
            <div class="pt-6 border-t border-gray-800">
                <button type="submit" class="w-full bg-[#00C897] hover:bg-[#0a9b77] text-white font-bold uppercase py-4 rounded-xl text-sm cursor-pointer transition-colors flex justify-center items-center gap-2">
                    <i class="fa-solid fa-paper-plane"></i> Publicar Vacante
                </button>
            </div>

        </form>
    </div>
</div>