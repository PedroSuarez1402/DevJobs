<div class="max-w-5xl mx-auto mt-6 px-4">
    {{!-- Botón Volver --}}
    <div class="mb-6">
        <a href="/vacantes" class="inline-flex items-center gap-2 text-gray-400 hover:text-emerald-400 transition-colors text-sm font-medium group">
            <i class="fa-solid fa-arrow-left transition-transform group-hover:-translate-x-1"></i>
            Volver a las vacantes
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {{!-- Columna Principal: Detalles de la Vacante --}}
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-sm">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h1 class="text-3xl font-black text-white mb-2 tracking-tight">{{vacante.titulo}}</h1>
                        <div class="flex flex-wrap gap-4 text-sm text-gray-400">
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-building text-emerald-500"></i>
                                <span class="font-bold text-gray-300">{{vacante.creador.nombre}}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-location-dot text-emerald-500"></i>
                                <span>{{vacante.ubicacion}}</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <i class="fa-solid fa-calendar-day text-emerald-500"></i>
                                <span>Publicado el {{vacante.fecha_publicacion}}</span>
                            </div>
                        </div>
                    </div>
                    <span class="px-3 py-1 bg-emerald-500/10 text-emerald-400 text-[10px] font-black uppercase rounded-full border border-emerald-500/20">
                        {{vacante.tipo_contrato}}
                    </span>
                </div>

                {{!-- Resumen Rápido --}}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-4 bg-gray-950/50 rounded-xl border border-gray-800 mb-8">
                    <div class="text-center border-r border-gray-800">
                        <p class="text-[10px] uppercase font-black text-gray-500 mb-1">Salario</p>
                        <p class="text-lg font-bold text-white">${{vacante.salario}}</p>
                    </div>
                    <div class="text-center">
                        <p class="text-[10px] uppercase font-black text-gray-500 mb-1">Contrato</p>
                        <p class="text-lg font-bold text-white">{{vacante.tipo_contrato}}</p>
                    </div>
                </div>

                {{!-- Descripción --}}
                <div class="prose prose-invert max-w-none">
                    <h2 class="text-xl font-bold text-white mb-4 border-b border-gray-800 pb-2">Descripción del Puesto</h2>
                    <div class="text-gray-400 leading-relaxed whitespace-pre-wrap">{{vacante.descripcion}}</div>
                </div>
            </div>
        </div>

        {{!-- Columna Lateral: Acciones y Reclutador --}}
        <div class="space-y-6">
            {{!-- Card de Acción --}}
            <div class="bg-emerald-500 p-6 rounded-2xl shadow-lg shadow-emerald-500/10">
                <h3 class="text-gray-950 text-lg font-black mb-4">¿Te interesa este puesto?</h3>
                <p class="text-emerald-950 text-sm mb-6 leading-snug">Asegúrate de tener tu perfil actualizado antes de postularte.</p>
                <button class="w-full bg-gray-950 hover:bg-gray-900 text-white font-black uppercase py-4 rounded-xl text-xs transition-all transform hover:-translate-y-1 active:scale-95">
                    Postularme Ahora
                </button>
            </div>

            {{!-- Información del Reclutador --}}
            <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
                <h3 class="text-white font-bold mb-4 text-sm uppercase tracking-wider">Sobre el Reclutador</h3>
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-12 h-12 rounded-full bg-gray-800 flex items-center justify-center overflow-hidden border border-gray-700">
                        {{#if vacante.creador.foto_perfil}}
                            <img src="/uploads/perfiles/{{vacante.creador.foto_perfil}}" alt="{{vacante.creador.nombre}}" class="w-full h-full object-cover">
                        {{else}}
                            <i class="fa-solid fa-user text-gray-600 text-xl"></i>
                        {{/if}}
                    </div>
                    <div>
                        <p class="text-white font-bold text-sm">{{vacante.creador.nombre}}</p>
                        <p class="text-gray-500 text-xs">{{vacante.creador.email}}</p>
                    </div>
                </div>
                <a href="/perfil/{{vacante.creador.id}}" class="block w-full text-center border border-gray-700 hover:border-emerald-500 text-gray-400 hover:text-emerald-400 py-2.5 rounded-lg text-xs font-bold transition-all">
                    Ver Perfil Completo
                </a>
            </div>

            {{!-- Compartir --}}
            <div class="flex justify-center gap-4">
                <button class="p-3 bg-gray-900 border border-gray-800 rounded-xl text-gray-400 hover:text-white transition-colors">
                    <i class="fa-brands fa-linkedin-in"></i>
                </button>
                <button class="p-3 bg-gray-900 border border-gray-800 rounded-xl text-gray-400 hover:text-white transition-colors">
                    <i class="fa-brands fa-twitter"></i>
                </button>
                <button class="p-3 bg-gray-900 border border-gray-800 rounded-xl text-gray-400 hover:text-white transition-colors">
                    <i class="fa-solid fa-link"></i>
                </button>
            </div>
        </div>
    </div>
</div>
